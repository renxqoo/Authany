# =========================
# Admin Web 管理后台
# =========================

# Admin Web 访问 AuthAny API 时使用的内部地址。
# 通常是内网地址、容器服务名或本机回环地址。
AUTHANY_INTERNAL_URL=http://127.0.0.1:3000

# Admin Web 对应的 OAuth Client ID
AUTHANY_ADMIN_CLIENT_ID=authany-admin-web

# Admin Web 对应的 OAuth Client Secret
AUTHANY_ADMIN_CLIENT_SECRET=replace-with-admin-client-secret

# Admin Web 对外公开访问地址。
# 必须与后台 OAuth Redirect URI 配置一致。
ADMIN_WEB_PUBLIC_URL=http://127.0.0.1:3005

# Admin Web 自己的会话签名密钥。
# 生产环境必须替换为高强度随机值，长度至少 32 字节。
ADMIN_WEB_SESSION_SECRET=replace-with-admin-web-session-secret-at-least-32-bytes
