# Shared example runtime config loaded by both example/demo-web and example/target-service.
#
# Copy this file to example/.env and edit the values there.

# =========================
# Demo Web 示例业务应用
# =========================

# Demo Web 访问 AuthAny API 时使用的内部地址。
AUTHANY_INTERNAL_URL=http://127.0.0.1:3000

# Demo Web 对应的 OAuth Client ID
DEMO_WEB_CLIENT_ID=demo-web

# Demo Web 对应的 OAuth Client Secret
DEMO_WEB_CLIENT_SECRET=replace-with-demo-web-client-secret

# Demo Web OAuth 回调地址。
# 必须与后台 OAuth Redirect URI 配置一致。
DEMO_WEB_REDIRECT_URI=http://127.0.0.1:5173/callback

# Demo Web 自己的会话签名密钥。
# 生产环境必须替换为高强度随机值，长度至少 32 字节。
DEMO_WEB_SESSION_SECRET=replace-with-demo-web-session-secret-at-least-32-bytes

# Demo Web 代表哪个 Agent 发起 requester token / target token 请求
DEMO_AGENT_ID=agent_demo

# Demo Web 使用的 Runtime Registration ID。
# 该值由 `pnpm seed` 输出，或从 Admin Web 的 Runtime Registrations 页面复制。
DEMO_RUNTIME_ID=replace-with-seeded-runtime-id

# Demo Web 调用 requester token 接口时使用的 Agent Credential
DEMO_AGENT_CREDENTIAL=replace-with-agent-credential

# Demo Web 访问的目标资源编码。
DEMO_TARGET_RESOURCE=demo-target

# Demo Web 调用示例目标资源服务的访问地址
DEMO_TARGET_SERVICE_URL=http://127.0.0.1:3006


# =========================
# OpenClaw CLI 示例
# =========================

# 业务 CLI 调用的目标资源服务地址。
# OpenClaw 给 CLI 注入短期 token 时，CLI 本身通常只需要这个地址和 AUTHANY_TARGET_ACCESS_TOKEN。
TARGET_SERVICE_URL=http://127.0.0.1:3006

# 以下变量用于本地单独运行 CLI 自测。
# 真正走 OpenClaw 集成时，长期凭证应该保留在 OpenClaw 宿主进程，不应进入业务 CLI 子进程。
AUTHANY_CALLER_CREDENTIAL=replace-with-agent-credential
AUTHANY_AGENT_ID=agent_demo
AUTHANY_RUNTIME_ID=replace-with-seeded-runtime-id
AUTHANY_TARGET_RESOURCE=demo-target


# =========================
# Target Service 示例目标资源服务
# =========================

# 示例目标资源服务监听端口
TARGET_SERVICE_PORT=3006

# 目标资源服务校验 Target Token 时信任的 AuthAny issuer
AUTHANY_ISSUER=http://127.0.0.1:3000

# 目标资源服务要求的 audience
TARGET_SERVICE_AUDIENCE=demo-target

# 目标资源服务要求的 target_resource 编码
TARGET_RESOURCE_CODE=demo-target

# 本地登录 JWT 签名密钥（生产环境必须替换为高强度随机值，至少 32 字节）
JWT_SECRET=replace-with-jwt-secret-at-least-32-bytes

# 目标资源服务连接的 PostgreSQL 数据库
DB_HOST=115.190.199.161
DB_PORT=5432
DB_NAME=quantagent
DB_USER=quantagent
DB_PASSWORD=quantagent123
