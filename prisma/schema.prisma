generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OperatorAccount {
  id                     String               @id @default(cuid())
  tenantId               String               @map("tenant_id")
  username               String
  passwordHash           String               @map("password_hash")
  displayName            String               @map("display_name")
  email                  String?
  mobile                 String?
  status                 String
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  authorizationCodes     OAuthAuthorizationCode[]
  refreshTokens          OAuthRefreshToken[]
  auditEvents            AuditEvent[]
  roles                  OperatorRole[]

  @@unique([tenantId, username])
  @@map("operator_accounts")
}

model OperatorRole {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  operatorId String   @map("operator_id")
  roleCode   String   @map("role_code")
  scope      String
  status     String
  createdAt  DateTime @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  operator   OperatorAccount @relation(fields: [operatorId], references: [id])

  @@unique([tenantId, operatorId, roleCode])
  @@index([operatorId, status])
  @@map("operator_roles")
}

model OAuthClient {
  id                String                  @id @default(cuid())
  tenantId          String                  @map("tenant_id")
  clientId          String                  @map("client_id")
  clientType        String                  @map("client_type")
  name              String
  description       String?
  status            String
  allowedGrantTypes Json                    @map("allowed_grant_types")
  allowedScopes     Json                    @map("allowed_scopes")
  ownerType         String?                 @map("owner_type")
  ownerId           String?                 @map("owner_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  deletedAt         DateTime?               @map("deleted_at")
  secrets           OAuthClientSecret[]
  redirectUris      OAuthRedirectUri[]
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens      OAuthAccessTokenRecord[]
  refreshTokens     OAuthRefreshToken[]

  @@unique([tenantId, clientId])
  @@map("oauth_clients")
}

model OAuthClientSecret {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  clientId   String      @map("client_id")
  secretHash String      @map("secret_hash")
  secretCiphertext String? @map("secret_ciphertext")
  encryptionKeyId String? @map("encryption_key_id")
  hint       String      @default("")
  status     String
  issuedAt   DateTime    @default(now()) @map("issued_at")
  expiresAt  DateTime?   @map("expires_at")
  viewedAt   DateTime?   @map("viewed_at")
  lastUsedAt DateTime?   @map("last_used_at")
  revokedAt  DateTime?   @map("revoked_at")
  client     OAuthClient @relation(fields: [clientId], references: [id])

  @@map("oauth_client_secrets")
}

model OAuthRedirectUri {
  id          String      @id @default(cuid())
  tenantId    String      @map("tenant_id")
  clientId    String      @map("client_id")
  redirectUri String      @map("redirect_uri")
  createdAt   DateTime    @default(now()) @map("created_at")
  client      OAuthClient @relation(fields: [clientId], references: [id])

  @@unique([clientId, redirectUri])
  @@map("oauth_redirect_uris")
}

model OAuthAuthorizationCode {
  id                  String      @id @default(cuid())
  tenantId            String      @map("tenant_id")
  codeHash            String      @unique @map("code_hash")
  clientId            String      @map("client_id")
  operatorId          String      @map("operator_id")
  redirectUri         String      @map("redirect_uri")
  scope               String
  codeChallenge       String      @map("code_challenge")
  codeChallengeMethod String      @map("code_challenge_method")
  status              String
  state               String?
  nonce               String?
  expiresAt           DateTime    @map("expires_at")
  consumedAt          DateTime?   @map("consumed_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  client              OAuthClient @relation(fields: [clientId], references: [id])
  operator            OperatorAccount @relation(fields: [operatorId], references: [id])

  @@index([clientId, status])
  @@map("oauth_authorization_codes")
}

model OAuthAccessTokenRecord {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  jti          String      @unique
  tokenType    String      @map("token_type")
  subjectType  String      @map("subject_type")
  subjectId    String      @map("subject_id")
  clientId     String?     @map("client_id")
  audience     String?
  scope        String
  claimsJson   Json        @map("claims_json")
  issuedAt     DateTime    @default(now()) @map("issued_at")
  expiresAt    DateTime    @map("expires_at")
  client       OAuthClient? @relation(fields: [clientId], references: [id])

  @@index([subjectId, subjectType])
  @@map("oauth_access_token_records")
}

model OAuthRefreshToken {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  jti               String      @unique
  tokenHash         String      @unique @map("token_hash")
  clientId          String      @map("client_id")
  operatorId        String      @map("operator_id")
  status            String
  scope             String
  issuedAt          DateTime    @default(now()) @map("issued_at")
  expiresAt         DateTime    @map("expires_at")
  revokedAt         DateTime?   @map("revoked_at")
  replacedByTokenId String?     @map("replaced_by_token_id")
  client            OAuthClient @relation(fields: [clientId], references: [id])
  operator          OperatorAccount @relation(fields: [operatorId], references: [id])

  @@index([clientId, operatorId, status])
  @@map("oauth_refresh_tokens")
}

model TokenRevocation {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tokenJti   String   @map("token_jti")
  tokenType  String   @map("token_type")
  reason     String
  revokedAt  DateTime @default(now()) @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tokenJti, tokenType])
  @@unique([tokenJti, tokenType], map: "token_jti_token_type")
  @@map("token_revocations")
}

model AgentProfile {
  id          String               @id @default(cuid())
  tenantId    String               @map("tenant_id")
  agentId     String               @map("agent_id")
  name        String
  status      String
  description String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")
  runtimes    RuntimeRegistration[]
  credentials CallerCredential[]
  auditEvents AuditEvent[]

  @@unique([tenantId, agentId])
  @@map("agent_profiles")
}

model RuntimeRegistration {
  id                        String             @id @default(cuid())
  tenantId                  String             @map("tenant_id")
  runtimeId                 String             @map("runtime_id")
  agentId                   String             @map("agent_id")
  runtimeType               String             @map("runtime_type")
  runtimeMode               String             @map("runtime_mode")
  status                    String
  credentialDeliveryMode    String             @default("bearer") @map("credential_delivery_mode")
  allowsDelegationRefresh   Boolean            @default(false) @map("allows_delegation_refresh")
  allowsRemoteCacheReuse    Boolean            @default(false) @map("allows_remote_cache_reuse")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")
  agent                     AgentProfile       @relation(fields: [agentId], references: [id])
  credentials               CallerCredential[]
  connections               TargetConnection[]

  @@unique([tenantId, runtimeId])
  @@index([agentId, runtimeMode, status])
  @@map("runtime_registrations")
}

model CallerCredential {
  id                         String               @id @default(cuid())
  tenantId                   String               @map("tenant_id")
  agentId                    String               @map("agent_id")
  runtimeRegistrationId      String?              @map("runtime_registration_id")
  credentialType             String               @map("credential_type")
  credentialHint             String               @map("credential_hint")
  secretHashOrPublicKeyRef   String               @map("secret_hash_or_public_key_ref")
  status                     String
  issuedAt                   DateTime             @default(now()) @map("issued_at")
  expiresAt                  DateTime?            @map("expires_at")
  lastUsedAt                 DateTime?            @map("last_used_at")
  revokedAt                  DateTime?            @map("revoked_at")
  agent                      AgentProfile         @relation(fields: [agentId], references: [id])
  runtime                    RuntimeRegistration? @relation(fields: [runtimeRegistrationId], references: [id])

  @@index([agentId, status])
  @@map("caller_credentials")
}

model TargetResourceRegistration {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  targetResourceCode    String   @map("target_resource_code")
  displayName         String   @map("display_name")
  audience            String
  status              String
  tokenValidationMode String   @map("token_validation_mode")
  trustConfigJson     Json     @map("trust_config_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  connections         TargetConnection[]

  @@unique([tenantId, targetResourceCode])
  @@map("target_resource_registrations")
}

model TargetConnection {
  id                          String    @id @default(cuid())
  tenantId                    String    @map("tenant_id")
  connectionId                String    @map("connection_id")
  principalType               String    @map("principal_type")
  principalId                 String    @map("principal_id")
  runtimeRegistrationId       String?   @map("runtime_registration_id")
  targetResourceId              String    @map("target_resource_id")
  targetResource                String    @map("target_resource")
  externalContextMode         String    @map("external_context_mode")
  allowedContextProvidersJson Json      @map("allowed_context_providers_json")
  maxTokenTtlSeconds          Int       @map("max_token_ttl_seconds")
  status                      String
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  expiresAt                   DateTime? @map("expires_at")
  runtime                     RuntimeRegistration? @relation(fields: [runtimeRegistrationId], references: [id])
  target                      TargetResourceRegistration @relation(fields: [targetResourceId], references: [id])
  grants                      AccessGrant[]

  @@unique([tenantId, connectionId])
  @@index([principalType, principalId, targetResource, status])
  @@index([runtimeRegistrationId, targetResource, status])
  @@map("target_connections")
}

model AccessGrant {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  grantId         String           @map("grant_id")
  connectionId    String           @map("connection_id")
  grantType       String           @map("grant_type")
  effect          String
  constraintsJson Json             @map("constraints_json")
  status          String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  expiresAt       DateTime         @map("expires_at")
  connection      TargetConnection @relation(fields: [connectionId], references: [id])

  @@unique([tenantId, grantId])
  @@index([connectionId, status, expiresAt])
  @@map("access_grants")
}

model AuditEvent {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  eventType    String   @map("event_type")
  operatorId   String?  @map("operator_id")
  clientId     String?  @map("client_id")
  agentId      String?  @map("agent_id")
  targetResource String?  @map("target_resource")
  result       String
  errorCode    String?  @map("error_code")
  requestId    String?  @map("request_id")
  payloadJson  Json?    @map("payload_json")
  occurredAt   DateTime @default(now()) @map("occurred_at")
  operator     OperatorAccount? @relation(fields: [operatorId], references: [id])
  agent        AgentProfile? @relation(fields: [agentId], references: [id])

  @@index([eventType, occurredAt])
  @@map("audit_events")
}

model KeyRotationRecord {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  kid        String
  algorithm  String
  status     String
  activatedAt DateTime? @map("activated_at")
  retiredAt  DateTime? @map("retired_at")
  metadataJson Json?  @map("metadata_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([kid, status])
  @@map("key_rotation_records")
}
