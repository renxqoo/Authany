# =========================
# AuthAny 主服务
# =========================

# 运行环境：development / test / production
NODE_ENV=development

# AuthAny API 服务监听端口
PORT=3000

# AuthAny 对外基础地址。
# 用于 JWT issuer、OIDC 元数据、回调地址拼接等，必须填写真实可访问地址。
AUTHANY_BASE_URL=http://127.0.0.1:3000

# PostgreSQL 连接串
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/authany?schema=public

# Redis 连接串
REDIS_URL=redis://127.0.0.1:6379

# 登录 Session Cookie 签名密钥。
# 生产环境必须替换为高强度随机值，长度至少 32 字节。
COOKIE_SECRET=replace-with-cookie-secret-at-least-32-bytes

# 当前租户 ID。
# 整个实例内的数据隔离依赖此值，禁止依赖默认租户概念。
TENANT_ID=default

# 应用级密钥加密主密钥。
# 用于加密私钥、client secret 等敏感数据，生产环境必须替换为高强度随机值，长度至少 32 字节。
AUTHANY_APP_SECRET_ENCRYPTION_KEY=replace-with-app-secret-encryption-key-at-least-32-bytes

# 登录 Cookie 名称
AUTHANY_LOGIN_COOKIE_NAME=authany_session

# OAuth 授权码有效期（秒）
AUTHANY_AUTH_CODE_TTL_SECONDS=300

# OAuth Access Token 有效期（秒）
AUTHANY_ACCESS_TOKEN_TTL_SECONDS=3600

# OAuth Refresh Token 有效期（秒）
AUTHANY_REFRESH_TOKEN_TTL_SECONDS=2592000

# Target Access Token 有效期（秒）
AUTHANY_TARGET_TOKEN_TTL_SECONDS=900

# Target Token 复用阈值（秒）。
# 距离过期时间小于该值时不再复用缓存 token。
AUTHANY_TARGET_TOKEN_REUSE_THRESHOLD_SECONDS=60

# Delegation 重放保护窗口（秒）
AUTHANY_REPLAY_TTL_SECONDS=300

# 允许提交登录/授权表单的来源列表，多个用逗号分隔。
# 例如 Admin Web、Demo Web 的来源地址。
AUTHANY_CSP_FORM_ACTION_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3005

# 允许跨域调用 AuthAny API 的来源列表，多个用逗号分隔。
AUTHANY_CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3005

# 可信反向代理地址列表，多个用逗号分隔。
# 只有在你明确知道前面有可信代理，并且代理会清理 X-Forwarded-* 头时才填写。
AUTHANY_TRUSTED_PROXIES=

# =========================
# Demo Seed（仅本地示例初始化）
# =========================

# Demo Web OAuth Client Secret。
# `pnpm seed` 会把它写入数据库，并打印给示例应用使用。
SEED_CLIENT_SECRET=replace-with-demo-web-client-secret

# Admin Web OAuth Client Secret。
# `pnpm seed` 会把它写入数据库，供 Admin Web 登录换取 token。
SEED_ADMIN_CLIENT_SECRET=replace-with-admin-web-client-secret

# Demo Agent 的 caller credential 明文。
# `pnpm seed` 会写入哈希值，并仅在脚本输出中回显一次明文。
SEED_CALLER_CREDENTIAL=replace-with-demo-agent-credential
