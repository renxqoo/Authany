{
  "name": "authany",
  "version": "0.1.0",
  "private": true,
  "description": "AuthAny V1 authorization platform",
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "pnpm build && node dist/src/main.js",
    "dev:all": "concurrently -k --names api,admin,demo,target -c blue,green,magenta,cyan \"pnpm dev\" \"pnpm admin:dev\" \"pnpm demo:dev\" \"pnpm target:dev\"",
    "start": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "admin:dev": "pnpm --filter @authany/admin-web dev",
    "admin:build": "pnpm --filter @authany/admin-web build",
    "admin:test": "pnpm --filter @authany/admin-web test",
    "admin:lint": "pnpm --filter @authany/admin-web lint",
    "admin:typecheck": "pnpm --filter @authany/admin-web typecheck",
    "demo:dev": "pnpm --filter ./example/demo-web dev",
    "demo:build": "pnpm --filter ./example/demo-web build",
    "demo:test": "pnpm --filter ./example/demo-web test",
    "demo:lint": "pnpm --filter ./example/demo-web lint",
    "demo:typecheck": "pnpm --filter ./example/demo-web typecheck",
    "target:dev": "pnpm --filter ./example/target-service dev",
    "target:build": "pnpm --filter ./example/target-service build",
    "target:test": "pnpm --filter ./example/target-service test",
    "target:lint": "pnpm --filter ./example/target-service lint",
    "target:typecheck": "pnpm --filter ./example/target-service typecheck"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/testing": "^11.1.6",
    "@prisma/client": "^6.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.3.3",
    "jose": "^6.0.11",
    "prisma": "^6.8.2",
    "redis": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "concurrently": "^9.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
