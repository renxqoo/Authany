    "@prisma/client": "^6.8.2",
    "fastify": "^5.3.3",
    "jose": "^6.0.11",
    "prisma": "^6.8.2",
    "redis": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.2.4",
