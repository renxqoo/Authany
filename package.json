{
  "name": "authany",
  "version": "0.1.0",
  "private": true,
  "description": "AuthAny monorepo workspace",
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm --filter @authany/server build",
    "dev": "pnpm --filter @authany/server dev",
    "dev:all": "concurrently -k --names api,admin,demo,target -c blue,green,magenta,cyan \"pnpm dev\" \"pnpm admin:dev\" \"pnpm demo:dev\" \"pnpm target:dev\"",
    "start": "pnpm --filter @authany/server build && pnpm --filter @authany/server start",
    "prisma:generate": "pnpm --filter @authany/server prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @authany/server prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @authany/server prisma:migrate:deploy",
    "prisma:push": "pnpm --filter @authany/server prisma:push",
    "seed": "pnpm --filter @authany/server seed",
    "test": "pnpm --filter @authany/server test",
    "test:watch": "pnpm --filter @authany/server test:watch",
    "test:coverage": "pnpm --filter @authany/server test:coverage",
    "server:typecheck": "pnpm --filter @authany/server typecheck",
    "admin:dev": "pnpm --filter @authany/admin-web dev",
    "admin:build": "pnpm --filter @authany/admin-web build",
    "admin:test": "pnpm --filter @authany/admin-web test",
    "admin:lint": "pnpm --filter @authany/admin-web lint",
    "admin:typecheck": "pnpm --filter @authany/admin-web typecheck",
    "demo:dev": "pnpm --filter @authany/demo-web dev",
    "demo:build": "pnpm --filter @authany/demo-web build",
    "demo:test": "pnpm --filter @authany/demo-web test",
    "demo:lint": "pnpm --filter @authany/demo-web lint",
    "demo:typecheck": "pnpm --filter @authany/demo-web typecheck",
    "target:dev": "pnpm --filter @authany/target-service dev",
    "target:build": "pnpm --filter @authany/target-service build",
    "target:test": "pnpm --filter @authany/target-service test",
    "target:lint": "pnpm --filter @authany/target-service lint",
    "target:typecheck": "pnpm --filter @authany/target-service typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
