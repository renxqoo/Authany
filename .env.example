NODE_ENV=development
PORT=3000
AUTHANY_BASE_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/authany?schema=public
REDIS_URL=redis://127.0.0.1:6379
ADMIN_API_TOKEN=change-me-admin-token
COOKIE_SECRET=change-me-cookie-secret
TENANT_ID=default
AUTHANY_JWT_PRIVATE_KEY_PEM=
AUTHANY_JWT_PUBLIC_KEY_PEM=
AUTHANY_LOGIN_COOKIE_NAME=authany_session
AUTHANY_BINDING_TTL_SECONDS=900
AUTHANY_AUTH_CODE_TTL_SECONDS=300
AUTHANY_ACCESS_TOKEN_TTL_SECONDS=3600
AUTHANY_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTHANY_DELEGATION_TOKEN_TTL_SECONDS=900
AUTHANY_REPLAY_TTL_SECONDS=300
